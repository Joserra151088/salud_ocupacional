# Servidor
PORT=3000
NODE_ENV=production

# Base de datos MySQL (AWS RDS)
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=3306
DB_USER=previta_user
DB_PASSWORD=your_secure_password
DB_NAME=previta_ohp

# JWT
JWT_SECRET=replace_with_64_random_chars_minimum
JWT_EXPIRES_IN=8h

# CORS — pon aquí el dominio de tu frontend
CORS_ORIGIN=https://ohp.tudominio.com
